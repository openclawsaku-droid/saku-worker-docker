# Saku Worker Docker - Environment Variables
# このファイルをコピーして .env を作成してください

# Discord Bot Token for ぷーちゃん
PU_CHAN_DISCORD_TOKEN=your-pu-chan-token-here

# Discord Bot Token for ピノ
PINO_DISCORD_TOKEN=your-pino-token-here

# OpenClaw Gateway Token (optional, for connection auth)
# OPENCLAW_GATEWAY_TOKEN=your-gateway-token-here
